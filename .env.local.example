# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NoteStash

# ─── Admin ────────────────────────────────────────────────────────────────────
# The email address(es) that get admin access — comma-separated
ADMIN_EMAILS=you@youremail.com

# ─── Session security ─────────────────────────────────────────────────────────
# Random secret for session tokens — generate one at: https://generate-secret.vercel.app/32
SESSION_SECRET=change-this-to-a-random-secret-string
